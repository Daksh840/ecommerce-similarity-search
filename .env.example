# =============================================================================
# E-Commerce Similarity Search — Environment Configuration
# =============================================================================
# Copy this file to .env and modify as needed.
# All values shown are defaults — only set what you want to override.
# =============================================================================

# --- App ---
APP_NAME="E-Commerce Similarity Search API"
APP_VERSION="1.0.0"
DEBUG=false

# --- Model ---
MODEL_NAME=resnet50
EMBEDDING_DIMENSION=2048
BATCH_SIZE=32

# --- FAISS Index ---
INDEX_PATH=data/faiss_index
INDEX_TYPE=IndexFlatIP

# --- Data ---
DATA_DIR=data
IMAGE_DIR=data/images
DATA_PATH=data/products.json

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
REDIS_URL=redis://localhost:6379
MAX_UPLOAD_SIZE_MB=10
DEFAULT_TOP_K=5
MAX_TOP_K=20

# --- Preprocessing ---
MIN_IMAGE_SIZE=64
MAX_IMAGE_SIZE=4096
SUPPORTED_FORMATS=["JPEG","PNG","WEBP","BMP"]

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT="%(asctime)s | %(levelname)-8s | %(name)s | %(message)s"
